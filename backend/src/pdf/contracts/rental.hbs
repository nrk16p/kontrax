<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@400;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Sarabun', 'TH Sarabun New', serif;
    font-size: 14pt;
    line-height: 1.8;
    color: #111;
    background: #fff;
    padding: 0;
  }

  .page {
    width: 210mm;
    min-height: 297mm;
    padding: 20mm 25mm;
    margin: 0 auto;
  }

  h1 {
    text-align: center;
    font-size: 18pt;
    font-weight: 700;
    margin-bottom: 6pt;
    letter-spacing: 1px;
  }

  .subtitle {
    text-align: center;
    font-size: 12pt;
    color: #555;
    margin-bottom: 24pt;
  }

  .contract-no {
    text-align: right;
    font-size: 11pt;
    color: #666;
    margin-bottom: 16pt;
  }

  .section {
    margin-bottom: 16pt;
  }

  .section-title {
    font-weight: 700;
    font-size: 14pt;
    border-bottom: 1.5px solid #222;
    padding-bottom: 3pt;
    margin-bottom: 8pt;
  }

  .party-block {
    background: #f9f9f9;
    border-left: 3px solid #333;
    padding: 10pt 14pt;
    margin: 8pt 0 12pt;
    border-radius: 0 4px 4px 0;
  }

  .party-block p { margin: 3pt 0; }

  .clause {
    margin: 8pt 0;
    padding-left: 14pt;
  }

  .clause-num {
    font-weight: 600;
  }

  table.terms {
    width: 100%;
    border-collapse: collapse;
    margin: 8pt 0 16pt;
    font-size: 13pt;
  }

  table.terms td {
    padding: 6pt 10pt;
    border: 0.5px solid #ccc;
    vertical-align: top;
  }

  table.terms td:first-child {
    width: 40%;
    background: #f4f4f4;
    font-weight: 600;
  }

  .rules-list {
    list-style: none;
    padding: 0;
    margin: 6pt 0;
  }

  .rules-list li {
    padding: 4pt 0 4pt 16pt;
    position: relative;
  }

  .rules-list li::before {
    content: "•";
    position: absolute;
    left: 4pt;
    color: #555;
  }

  .signature-section {
    margin-top: 40pt;
    page-break-inside: avoid;
  }

  .sig-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24pt;
    margin-top: 16pt;
  }

  .sig-box {
    text-align: center;
  }

  .sig-image {
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #333;
    margin-bottom: 6pt;
  }

  .sig-image img {
    max-height: 65px;
    max-width: 200px;
  }

  .sig-label { font-size: 12pt; color: #555; }
  .sig-name  { font-weight: 600; font-size: 13pt; margin-top: 2pt; }
  .sig-date  { font-size: 11pt; color: #666; }

  .watermark {
    position: fixed;
    bottom: 8mm;
    right: 10mm;
    font-size: 9pt;
    color: #bbb;
    letter-spacing: 0.5px;
  }

  .pdpa-notice {
    background: #f0f4ff;
    border: 0.5px solid #b0c4ee;
    border-radius: 4px;
    padding: 8pt 12pt;
    font-size: 11pt;
    color: #3a4a7a;
    margin-top: 20pt;
  }

  .special-conditions {
    background: #fffbe6;
    border-left: 3px solid #d4a017;
    padding: 10pt 14pt;
    border-radius: 0 4px 4px 0;
    font-size: 13pt;
  }
</style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <p class="contract-no">เลขที่สัญญา: {{contractNo}}</p>
  <h1>สัญญาเช่าอสังหาริมทรัพย์</h1>
  <p class="subtitle">Residential Rental Agreement</p>

  <p style="text-align:center; margin-bottom:20pt; font-size:13pt;">
    ทำขึ้น ณ วันที่ {{startDate}} | จัดทำโดย Kontrax
  </p>

  <!-- Parties -->
  <div class="section">
    <p class="section-title">คู่สัญญา</p>

    <p><strong>ฝ่ายที่ 1 ผู้ให้เช่า</strong></p>
    <div class="party-block">
      <p>ชื่อ: <strong>{{landlordName}}</strong></p>
      <p>เลขบัตรประชาชน: {{landlordId}}</p>
      <p>ที่อยู่: {{landlordAddress}}</p>
      <p>เบอร์โทรศัพท์: {{landlordPhone}}</p>
    </div>

    <p><strong>ฝ่ายที่ 2 ผู้เช่า</strong></p>
    <div class="party-block">
      <p>ชื่อ: <strong>{{tenantName}}</strong></p>
      <p>เลขบัตรประชาชน: {{tenantId}}</p>
      <p>ที่อยู่ปัจจุบัน: {{tenantAddress}}</p>
      <p>เบอร์โทรศัพท์: {{tenantPhone}}</p>
    </div>
  </div>

  <!-- Property -->
  <div class="section">
    <p class="section-title">ทรัพย์สินที่เช่า</p>
    <table class="terms">
      <tr><td>ที่อยู่ทรัพย์สิน</td><td>{{propertyAddress}}</td></tr>
      <tr><td>ประเภทที่พัก</td><td>{{propertyType}}</td></tr>
      {{#if projectName}}<tr><td>ชื่อโครงการ/อาคาร</td><td>{{projectName}}</td></tr>{{/if}}
      {{#if unitNo}}<tr><td>เลขที่ยูนิต/ห้อง</td><td>{{unitNo}}</td></tr>{{/if}}
      {{#if areaSqm}}<tr><td>พื้นที่ใช้สอย</td><td>{{areaSqm}} ตร.ม.</td></tr>{{/if}}
    </table>
  </div>

  <!-- Financial Terms -->
  <div class="section">
    <p class="section-title">เงื่อนไขทางการเงิน</p>
    <table class="terms">
      <tr><td>ค่าเช่าต่อเดือน</td><td><strong>{{rentAmount}} บาท</strong></td></tr>
      <tr><td>เงินประกัน</td><td>{{depositAmount}} บาท</td></tr>
      <tr><td>กำหนดชำระค่าเช่า</td><td>วันที่ {{paymentDueDay}} ของทุกเดือน</td></tr>
      <tr><td>ระยะเวลาเช่า</td><td>{{startDate}} ถึง {{endDate}}</td></tr>
    </table>
  </div>

  <!-- Clauses -->
  <div class="section">
    <p class="section-title">ข้อกำหนดและเงื่อนไข</p>

    <div class="clause">
      <span class="clause-num">ข้อ 1</span> ผู้ให้เช่าตกลงให้เช่าและผู้เช่าตกลงเช่าทรัพย์สินตามรายละเอียดข้างต้น
      ในระยะเวลาที่กำหนด โดยผู้เช่าจะต้องชำระค่าเช่าภายในวันที่กำหนดของทุกเดือน
    </div>

    <div class="clause">
      <span class="clause-num">ข้อ 2</span> ผู้เช่าจะต้องชำระเงินประกัน <strong>{{depositAmount}} บาท</strong>
      ก่อนเข้าพักอาศัย โดยผู้ให้เช่าจะคืนเงินประกันภายใน 30 วันหลังสิ้นสุดสัญญา
      หากไม่มีความเสียหายเกินกว่าการเสื่อมสภาพตามปกติ
    </div>

    <div class="clause">
      <span class="clause-num">ข้อ 3</span> ผู้เช่าต้องดูแลรักษาทรัพย์สินในสภาพที่ดี
      และรับผิดชอบต่อความเสียหายที่เกิดจากการกระทำของผู้เช่าหรือบุคคลในความดูแล
    </div>

    <div class="clause">
      <span class="clause-num">ข้อ 4</span> หากผู้เช่าผิดนัดชำระค่าเช่าเกินกว่า 30 วัน
      ผู้ให้เช่ามีสิทธิ์บอกเลิกสัญญาและเรียกร้องให้ผู้เช่าออกจากสถานที่ภายใน 15 วัน
    </div>

    <div class="clause">
      <span class="clause-num">ข้อ 5</span> การบอกเลิกสัญญาก่อนครบกำหนดต้องแจ้งล่วงหน้าไม่น้อยกว่า 30 วัน
      เป็นลายลักษณ์อักษร
    </div>

    {{#if specialConditions}}
    <div class="clause">
      <span class="clause-num">ข้อ 6 เงื่อนไขพิเศษ</span>
      <div class="special-conditions" style="margin-top:6pt;">{{specialConditions}}</div>
    </div>
    {{/if}}
  </div>

  <!-- PDPA Notice -->
  <div class="pdpa-notice">
    🔐 <strong>นโยบายคุ้มครองข้อมูลส่วนบุคคล (PDPA)</strong><br>
    ข้อมูลส่วนบุคคลของคู่สัญญาทั้งสองฝ่ายถูกจัดเก็บและใช้เพื่อจัดทำสัญญานี้เท่านั้น
    ตาม พ.ร.บ. คุ้มครองข้อมูลส่วนบุคคล พ.ศ. 2562 คู่สัญญาทุกฝ่ายได้ให้ความยินยอม
    เมื่อ {{consentTimestamp}}
  </div>

  <!-- Signatures -->
  <div class="signature-section">
    <p class="section-title">ลายมือชื่อคู่สัญญา</p>
    <p style="font-size:12pt; color:#555; margin-bottom:8pt;">
      คู่สัญญาทั้งสองฝ่ายได้อ่านและเข้าใจข้อความในสัญญาโดยตลอดแล้ว จึงลงลายมือชื่อไว้เป็นหลักฐาน
    </p>

    <div class="sig-grid">
      <div class="sig-box">
        <div class="sig-image">
          {{#if landlordSignature}}
            <img src="{{landlordSignature}}" alt="landlord signature"/>
          {{else}}
            <span style="color:#bbb; font-size:12pt;">ยังไม่ได้ลงนาม</span>
          {{/if}}
        </div>
        <p class="sig-name">{{landlordName}}</p>
        <p class="sig-label">ผู้ให้เช่า (Party A)</p>
        <p class="sig-date">วันที่: {{landlordSignedAt}}</p>
      </div>

      <div class="sig-box">
        <div class="sig-image">
          {{#if tenantSignature}}
            <img src="{{tenantSignature}}" alt="tenant signature"/>
          {{else}}
            <span style="color:#bbb; font-size:12pt;">ยังไม่ได้ลงนาม</span>
          {{/if}}
        </div>
        <p class="sig-name">{{tenantName}}</p>
        <p class="sig-label">ผู้เช่า (Party B)</p>
        <p class="sig-date">วันที่: {{tenantSignedAt}}</p>
      </div>
    </div>
  </div>

</div>
<p class="watermark">จัดทำโดย Kontrax · kontrax.vercel.app · เอกสารอิเล็กทรอนิกส์ที่มีผลทางกฎหมาย</p>
</body>
</html>
