// firestore.rules
// Deploy: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users: own profile only ───────────────────────────────────────────────
    match /users/{uid} {
      allow read, update: if request.auth != null && request.auth.uid == uid;
      allow create:       if request.auth != null && request.auth.uid == uid;
      allow delete:       if false;  // Never delete via client
    }

    // ── Contracts: owner access only ─────────────────────────────────────────
    match /contracts/{contractId} {
      allow read, update:
        if request.auth != null && request.auth.uid == resource.data.createdBy;

      allow create:
        if request.auth != null
        && request.auth.uid == request.resource.data.createdBy;

      // Prevent editing signed contracts from the client
      allow update:
        if request.auth != null
        && request.auth.uid == resource.data.createdBy
        && resource.data.status in ["draft", "pending_signature"];

      allow delete: if false;  // Use soft-delete (status: terminated)
    }

    // ── Templates: public read, lawyer/admin write ────────────────────────────
    match /templates/{templateId} {
      allow read:  if true;
      allow write: if request.auth != null
        && request.auth.token.role in ["lawyer", "admin"];
    }

    // ── Audit Logs: server-side only ─────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read, write: if false;
    }

    // ── Default deny ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
